{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CopernicusAI Knowledge Engine - Video Data Metadata Schema",
  "description": "Unified metadata schema for scientific video/film data (microscopy, astronomical observations, experimental recordings) - distinct from educational/lecture videos. Video as DATA, not communication medium. Supports NSF Objective 2: Unified Multi-Modal Metadata Representation.",
  "type": "object",
  "required": [
    "id",
    "title",
    "source",
    "video_type",
    "acquired_date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier in format: video_data_{source}_{identifier} (e.g., video_data_microscopy_cell-division-001, video_data_astronomical_jupiter-rotation) - matches paper/video ID format for cross-modal linking"
    },
    "content_type": {
      "type": "string",
      "const": "video_data",
      "description": "Content type identifier - distinguishes from 'videos' (communication medium)"
    },
    "title": {
      "type": "string",
      "description": "Video data title/description",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"],
      "description": "Detailed description of the video data"
    },
    "source": {
      "type": "string",
      "enum": ["microscopy_lab", "telescope_observatory", "experiment", "archive", "repository", "manual", "other"],
      "description": "Source of video data"
    },
    "video_url": {
      "type": ["string", "null"],
      "description": "URL to video file",
      "format": "uri"
    },
    "thumbnail_url": {
      "type": ["string", "null"],
      "description": "URL to thumbnail/preview image",
      "format": "uri"
    },
    "format": {
      "type": "string",
      "enum": ["mp4", "avi", "mov", "mkv", "tiff_sequence", "other"],
      "description": "Video file format"
    },
    "duration": {
      "type": ["number", "null"],
      "description": "Duration in seconds"
    },
    "frame_rate": {
      "type": ["number", "null"],
      "description": "Frames per second (fps)"
    },
    "dimensions": {
      "type": ["object", "null"],
      "description": "Video dimensions and resolution",
      "properties": {
        "width": {"type": "integer"},
        "height": {"type": "integer"},
        "resolution_um_per_pixel": {
          "type": ["number", "null"],
          "description": "Spatial resolution in micrometers per pixel (for microscopy)"
        },
        "resolution_arcsec_per_pixel": {
          "type": ["number", "null"],
          "description": "Spatial resolution in arcseconds per pixel (for astronomy)"
        }
      }
    },
    "video_type": {
      "type": "string",
      "enum": ["microscopy", "astronomical", "experimental", "high_speed", "timelapse", "observation", "archival"],
      "description": "Type of scientific video data"
    },
    "recording_method": {
      "type": ["string", "null"],
      "enum": ["time_lapse", "real_time", "high_speed", "long_exposure", "stacked_images"],
      "description": "Recording/imaging method"
    },
    "imaging_technique": {
      "type": ["string", "null"],
      "enum": [
        "brightfield", "fluorescence", "phase_contrast", "differential_interference_contrast",
        "confocal", "electron_microscopy", "super_resolution",
        "optical_telescope", "radio_telescope", "space_telescope", "infrared",
        "x_ray", "ultraviolet"
      ],
      "description": "Imaging/observation technique"
    },
    "temporal_resolution": {
      "type": ["string", "null"],
      "description": "Temporal sampling rate (e.g., '1fps', '30fps', '1000fps')"
    },
    "spatial_resolution": {
      "type": ["object", "null"],
      "description": "Spatial resolution information",
      "properties": {
        "x": {"type": "number", "description": "Resolution in x direction (microns or arcseconds)"},
        "y": {"type": "number", "description": "Resolution in y direction"},
        "z": {"type": ["number", "null"], "description": "Resolution in z direction (for 3D/time-lapse)"}
      }
    },
    "time_span": {
      "type": ["object", "null"],
      "description": "Temporal span of the recording",
      "properties": {
        "start": {"type": ["string", "null"], "format": "date-time"},
        "end": {"type": ["string", "null"], "format": "date-time"},
        "duration_real_time": {
          "type": ["number", "null"],
          "description": "Real time duration in seconds (if time-lapse, this is the actual time span)"
        },
        "duration_recorded": {
          "type": ["number", "null"],
          "description": "Recorded video duration in seconds"
        }
      }
    },
    "experimental_conditions": {
      "type": ["object", "null"],
      "description": "Experimental/observation conditions",
      "properties": {
        "temperature": {"type": ["number", "null"], "description": "Temperature in Celsius"},
        "pressure": {"type": ["number", "null"], "description": "Pressure in atm"},
        "medium": {"type": ["string", "null"], "description": "Growth medium or environment"},
        "strain": {"type": ["string", "null"], "description": "Biological strain or sample type"},
        "treatment": {"type": ["string", "null"], "description": "Experimental treatment"},
        "wavelength": {"type": ["string", "null"], "description": "Observation wavelength (for astronomy/spectroscopy)"},
        "filter": {"type": ["string", "null"], "description": "Optical filter used"}
      }
    },
    "no_narration": {
      "type": "boolean",
      "default": true,
      "description": "Explicitly indicates this is data (no narration/audio) - distinguishes from educational videos"
    },
    "no_audio": {
      "type": "boolean",
      "default": true,
      "description": "Indicates video has no audio track (scientific data, not communication)"
    },
    "category": {
      "type": "string",
      "enum": ["biology", "chemistry", "physics", "mathematics", "computer_science", "interdisciplinary", "foundational"],
      "description": "Primary discipline category - matches other schemas for cross-modal linking"
    },
    "subcategories": {
      "type": "array",
      "description": "Sub-discipline categories",
      "items": {
        "type": "string"
      }
    },
    "keywords": {
      "type": "array",
      "description": "Extracted keywords (for cross-modal linking)",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags/labels",
      "items": {
        "type": "string"
      }
    },
    "year": {
      "type": ["string", "null"],
      "description": "Recording/creation year (YYYY format)",
      "pattern": "^[0-9]{4}$"
    },
    "url": {
      "type": ["string", "null"],
      "description": "URL to video data",
      "format": "uri"
    },
    "related_papers": {
      "type": "array",
      "description": "Related research papers (for cross-modal linking) - array of paper IDs",
      "items": {
        "type": "string"
      }
    },
    "related_videos": {
      "type": "array",
      "description": "Related educational videos (YouTube lectures, etc.) - array of video IDs",
      "items": {
        "type": "string"
      }
    },
    "related_processes": {
      "type": "array",
      "description": "Related process visualizations - array of process IDs",
      "items": {
        "type": "string"
      }
    },
    "related_podcasts": {
      "type": "array",
      "description": "Related podcast episodes - array of podcast IDs",
      "items": {
        "type": "string"
      }
    },
    "related_images": {
      "type": "array",
      "description": "Related images - array of image IDs",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "description": "Extracted entities (cells, organisms, structures, celestial objects) - for cross-modal linking",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["cell", "organism", "structure", "celestial_object", "protein", "compound", "concept", "method", "other"]
          },
          "name": {"type": "string"},
          "start_time": {
            "type": ["number", "null"],
            "description": "When entity appears in video (seconds)"
          },
          "end_time": {
            "type": ["number", "null"],
            "description": "When entity disappears (seconds)"
          },
          "position": {
            "type": ["object", "null"],
            "description": "Spatial position in frame (x, y, region)"
          }
        },
        "required": ["type", "name"]
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional flexible metadata",
      "properties": {
        "microscope_type": {
          "type": ["string", "null"],
          "enum": ["confocal", "electron", "light", "super_resolution", "atomic_force"]
        },
        "telescope_type": {
          "type": ["string", "null"],
          "enum": ["optical", "radio", "space_based", "ground_based", "infrared", "x_ray"]
        },
        "camera_settings": {"type": ["object", "null"]},
        "processing": {"type": ["object", "null"], "description": "Image processing steps"},
        "annotations": {"type": ["array", "null"], "description": "Manual or automated annotations"},
        "calibration": {"type": ["object", "null"], "description": "Spatial/temporal calibration data"},
        "instrument": {"type": ["string", "null"], "description": "Specific instrument used"},
        "location": {"type": ["object", "null"], "description": "Geographic or lab location"}
      },
      "additionalProperties": true
    },
    "quality_score": {
      "type": ["number", "null"],
      "description": "Overall quality score (0.0 to 1.0) - NSF requirement: >=0.85",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "acquired_date": {
      "type": "string",
      "description": "ISO 8601 timestamp of when metadata was acquired",
      "format": "date-time"
    },
    "recorded_date": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp of when video was recorded",
      "format": "date-time"
    },
    "license": {
      "type": ["string", "null"],
      "description": "License (CC-BY, CC0, public_domain, copyright, etc.)"
    },
    "credits": {
      "type": ["string", "null"],
      "description": "Attribution/credits information"
    },
    "embedding_id": {
      "type": ["string", "null"],
      "description": "Reference to vector DB embedding (for semantic search)"
    },
    "search_index_id": {
      "type": ["string", "null"],
      "description": "Reference to search index document"
    },
    "deduplication_method": {
      "type": ["string", "null"],
      "enum": ["unique", "exact_url_match", "hash_match", "content_fingerprint"],
      "description": "Method used for deduplication"
    },
    "deduplication_confidence": {
      "type": ["number", "null"],
      "description": "Confidence score for deduplication (0.0 to 1.0)",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "additionalProperties": true
}
