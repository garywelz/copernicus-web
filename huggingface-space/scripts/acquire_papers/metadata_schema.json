{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CopernicusAI Knowledge Engine - Paper Metadata Schema",
  "description": "Unified metadata schema for research papers supporting NSF Objective 2: Unified Multi-Modal Metadata Representation",
  "type": "object",
  "required": [
    "id",
    "title",
    "source",
    "acquired_date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier in format: {source}_{identifier} (e.g., pubmed_12345678, arxiv_2301.12345)"
    },
    "title": {
      "type": "string",
      "description": "Paper title",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "description": "List of author names",
      "items": {
        "type": "string"
      }
    },
    "author_string": {
      "type": "string",
      "description": "Formatted author string (e.g., 'Smith, J., Jones, A. et al.')"
    },
    "journal": {
      "type": "string",
      "description": "Journal name (abbreviated or full)"
    },
    "journal_full": {
      "type": "string",
      "description": "Full journal name"
    },
    "year": {
      "type": "string",
      "description": "Publication year (YYYY format)"
    },
    "doi": {
      "type": ["string", "null"],
      "description": "Digital Object Identifier",
      "pattern": "^10\\.[0-9]{4,}/.*$"
    },
    "abstract": {
      "type": "string",
      "description": "Paper abstract"
    },
    "keywords": {
      "type": "array",
      "description": "List of keywords",
      "items": {
        "type": "string"
      }
    },
    "categories": {
      "type": "array",
      "description": "Subject categories or classifications",
      "items": {
        "type": "string"
      }
    },
    "citation_count": {
      "type": ["integer", "null"],
      "description": "Number of citations (when available)"
    },
    "url": {
      "type": "string",
      "description": "URL to paper (preferred: stable URL like DOI or arXiv)",
      "format": "uri"
    },
    "source": {
      "type": "string",
      "enum": ["pubmed", "arxiv", "biorxiv", "medrxiv", "nasa_ads", "crossref"],
      "description": "Source database identifier"
    },
    "sources": {
      "type": "array",
      "description": "Additional source databases (for deduplication tracking)",
      "items": {
        "type": "string"
      }
    },
    "acquired_date": {
      "type": "string",
      "description": "ISO 8601 timestamp of when metadata was acquired",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": ["biology", "chemistry", "physics", "mathematics", "computer_science", "interdisciplinary", "foundational"],
      "description": "Primary discipline category"
    },
    "subcategories": {
      "type": "array",
      "description": "Sub-discipline categories",
      "items": {
        "type": "string"
      }
    },
    "pmid": {
      "type": ["string", "null"],
      "description": "PubMed ID (for PubMed papers)"
    },
    "arxiv_id": {
      "type": ["string", "null"],
      "description": "arXiv identifier (for arXiv papers)"
    },
    "bibcode": {
      "type": ["string", "null"],
      "description": "NASA ADS bibcode (for astronomy papers)"
    },
    "issn": {
      "type": ["string", "null"],
      "description": "International Standard Serial Number"
    },
    "publisher": {
      "type": ["string", "null"],
      "description": "Publisher name"
    },
    "language": {
      "type": ["string", "null"],
      "description": "Paper language (ISO 639-1 code preferred)"
    },
    "volume": {
      "type": ["string", "null"],
      "description": "Journal volume number"
    },
    "issue": {
      "type": ["string", "null"],
      "description": "Journal issue number"
    },
    "page": {
      "type": ["string", "null"],
      "description": "Page numbers"
    },
    "published_date": {
      "type": ["string", "null"],
      "description": "Publication date (ISO 8601 format)"
    },
    "updated_date": {
      "type": ["string", "null"],
      "description": "Last update date (ISO 8601 format)"
    },
    "deduplication_method": {
      "type": ["string", "null"],
      "enum": ["unique", "exact_doi_match", "exact_arxiv_match", "exact_pmid_match", "exact_bibcode_match", "title_author_match"],
      "description": "Method used for deduplication (null if not deduplicated)"
    },
    "deduplication_confidence": {
      "type": ["number", "null"],
      "description": "Confidence score for deduplication (0.0 to 1.0)",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "additionalProperties": true
}
