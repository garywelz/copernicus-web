    "and": 8,
    "not": 5,
    "or": 4
  },
  "mermaid": "graph TD\n    %% Pheromone Detection\n    A[Pheromone \u03b1-factor or a-factor] --> B{OR: Which<br/>Receptor?}\n    B -->|MATa cells| C[Ste2 GPCR binds \u03b1-factor]\n    B -->|MAT\u03b1 cells| D[Ste3 GPCR binds a-factor]\n    \n    C --> E[Ste2 Conformational Change]\n    D --> E\n    \n    %% G Protein Activation\n    E --> F[Gpa1-GDP G\u03b2\u03b3 Heterotrimer]\n    F --> G[GEF Activity]\n    G --> H[Gpa1-GTP Formation]\n    H --> I[G Protein Dissociation]\n    I --> J[\\Gpa1-GTP Inactive/]\n    I --> K[G\u03b2\u03b3 Ste4/Ste18 Active]\n    \n    %% Scaffold Recruitment\n    K --> L[Ste5 Scaffold Recruitment]\n    L --> M{AND: Ste5 + G\u03b2\u03b3<br/>Membrane?}\n    M -->|No| N[No Signaling]\n    M -->|Yes| O[Ste5 Membrane-Bound]\n    \n    %% MAPKKK Layer\n    O --> P[Ste11 MAPKKK Recruitment]\n    P --> Q{AND: Ste11 + Ste5<br/>+ Ste50?}\n    Q -->|No| N\n    Q -->|Yes| R[Ste11 Complex]\n    \n    R --> S[Ste20 PAK Kinase]\n    S --> T[Ste20 Phosphorylates Ste11]\n    T --> U[Ste11 Active]\n    \n    %% MAPKK Layer\n    U --> V[Ste7 MAPKK on Ste5]\n    V --> W{AND: Ste7 + Ste5<br/>Scaffold?}\n    W -->|No| N\n    W -->|Yes| X[Ste11 Phosphorylates Ste7]\n    \n    X --> Y[Ste7 Activated]\n    \n    %% MAPK Layer\n    Y --> Z{OR: Which<br/>MAPK?}\n    Z -->|Fus3 - Mating| AA[Fus3 MAPK]\n    Z -->|Kss1 - Invasion| AB[Kss1 MAPK]\n    \n    AA --> AC[Ste7 Phosphorylates Fus3]\n    AC --> AD[Fus3 Dual Phosphorylation]\n    AD --> AE[Fus3-PP Active]\n    \n    %% Fus3 Substrates\n    AE --> AF{OR: Which<br/>Substrate?}\n    AF -->|Ste12| AG[Ste12 Transcription Factor]\n    AF -->|Far1| AH[/Far1 CDK Inhibitor/]\n    AF -->|Ste5| AI[Ste5 Feedback]\n    AF -->|Msg5| AJ[/Msg5 Phosphatase/]\n    \n    %% Transcriptional Response\n    AG --> AK{AND: Ste12<br/>AND Dig1/2 Relief?}\n    AK -->|No| AL[\\Repressed/]\n    AK -->|Yes| AM[Dig1/2 Phosphorylated]\n    \n    AM --> AN[Dig1/2 Release]\n    AN --> AO[Ste12 Active]\n    AO --> AP[Ste12 Binds PRE Elements]\n    \n    AP --> AQ{OR: Which<br/>Mating Gene?}\n    AQ -->|FUS1| AR[FUS1 Cell Fusion]\n    AQ -->|FUS2| AS[FUS2 Cell Fusion]\n    AQ -->|AGA1/2| AT(\\1)\n    AQ -->|FAR1| AU[FAR1 G1 Arrest]\n    AQ -->|FIG1| AV[FIG1 Projection]\n    \n    %% Cell Cycle Arrest\n    AH --> AW[Far1 Accumulation]\n    AW --> AX{AND: Far1 + Cdc28-Cln?}\n    AX -->|No| AY[Cell Cycle Continues]\n    AX -->|Yes| AZ[\\Cdc28-Cln Inhibited/]\n    \n    AZ --> BA[G1 Arrest]\n    BA --> BB[Polarized Growth]\n    BB --> BC[Shmoo Formation]\n    \n    %% Morphological Changes\n    BC --> BD{AND: Actin<br/>Polarization?}\n    BD -->|No| BE[No Projection]\n    BD -->|Yes| BF[Actin Cables to Tip]\n    BF --> BG[Bni1 Formin]\n    BG --> BH[Projection Growth]\n    \n    %% Cell Fusion Preparation\n    AR --> BI[Fus1 Membrane Fusion Protein]\n    AS --> BI\n    AT --> BJ[Agglutinin Cell Adhesion]\n    BJ --> BK[Partner Cell Contact]\n    \n    BK --> BL{AND: Both Cells<br/>Shmoo?}\n    BL -->|No| BM[Mating Fails]\n    BL -->|Yes| BN[Cell Fusion Initiation]\n    \n    %% Cell Wall Degradation\n    BN --> BO[/Local Wall Degradation/]\n    BO --> BP{AND: Fus1 + Fus2<br/>Present?}\n    BP -->|No| BM\n    BP -->|Yes| BQ[Membrane Fusion]\n    \n    BQ --> BR[Cytoplasm Mixing]\n    BR --> BS[Nuclear Migration]\n    BS --> BT(\\1)\n    BT --> BU([Diploid Zygote])\n    \n    %% Negative Feedback\n    AI --> BV[Ste5 Phosphorylation]\n    BV --> BW[Ste5 Membrane Release]\n    BW --> BX[Signaling Attenuation]\n    \n    AJ --> BY[Msg5 Dephosphorylates Fus3]\n    BY --> BZ[Fus3 Inactivation]\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style B fill:#ffd600,color:#fff\n    style A fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill:#51cf66,color:#fff\n    style F fill:#b3e5fc,color:#000\n    style G fill:#b3e5fc,color:#000\n    style H fill:#b3e5fc,color:#000\n    style I fill:#ffa726,color:#fff\n    style J fill:#e74c3c,color:#fff\n    style K fill:#b3e5fc,color:#000\n    style L fill:#b3e5fc,color:#000\n    style M fill:#7950f2,color:#fff\n    style N fill:#51cf66,color:#fff\n    style O fill:#b3e5fc,color:#000\n    style P fill:#b3e5fc,color:#000\n    style Q fill:#7950f2,color:#fff\n    style R fill:#b3e5fc,color:#000\n    style S fill:#42a5f5,color:#fff\n    style T fill:#b3e5fc,color:#000\n    style U fill:#b3e5fc,color:#000\n    style V fill:#b3e5fc,color:#000\n    style W fill:#7950f2,color:#fff\n    style X fill:#b3e5fc,color:#000\n    style Y fill:#b3e5fc,color:#000\n    style Z fill:#ffd600,color:#fff\n    style AA fill:#b3e5fc,color:#000\n    style AB fill:#b3e5fc,color:#000\n    style AC fill:#b3e5fc,color:#000\n    style AD fill:#42a5f5,color:#fff\n    style AE fill:#b3e5fc,color:#000\n    style AF fill:#ffd600,color:#fff\n    style AG fill:#ffa726,color:#fff\n    style AH fill:#e74c3c,color:#fff\n    style AI fill:#b3e5fc,color:#000\n    style AJ fill:#42a5f5,color:#fff\n    style AK fill:#7950f2,color:#fff\n    style AL fill:#e74c3c,color:#fff\n    style AM fill:#b3e5fc,color:#000\n    style AN fill:#b3e5fc,color:#000\n    style AO fill:#b3e5fc,color:#000\n    style AP fill:#b3e5fc,color:#000\n    style AQ fill:#ffd600,color:#fff\n    style AR fill:#000000,color:#fff\n    style AS fill:#000000,color:#fff\n    style AT fill:#b3e5fc,color:#000\n    style AU fill:#b3e5fc,color:#000\n    style AV fill:#b3e5fc,color:#000\n    style AW fill:#b3e5fc,color:#000\n    style AX fill:#7950f2,color:#fff\n    style AY fill:#000000,color:#fff\n    style AZ fill:#e74c3c,color:#fff\n    style BA fill:#b3e5fc,color:#000\n    style BB fill:#000000,color:#fff\n    style BC fill:#b3e5fc,color:#000\n    style BD fill:#7950f2,color:#fff\n    style BE fill:#b3e5fc,color:#000\n    style BF fill:#b3e5fc,color:#000\n    style BG fill:#b3e5fc,color:#000\n    style BH fill:#000000,color:#fff\n    style BI fill:#f