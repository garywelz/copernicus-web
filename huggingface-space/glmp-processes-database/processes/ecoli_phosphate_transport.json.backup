    "and": 4,
    "not": 4,
    "or": 4
  },
  "mermaid": "graph TD\n    %% External Phosphate\n    A[Extracellular Phosphate Pi] --> B{OR: Pi<br/>Concentration?}\n    B -->|High >20 \u03bcM| C[Sufficient Phosphate]\n    B -->|Low <20 \u03bcM| D[Phosphate Starvation]\n    \n    %% High Pi - Pit System\n    C --> E[Pit Constitutive Transport]\n    E --> F[PitA/B H+ Symporters]\n    F --> G{AND: Pi + H+<br/>Gradient?}\n    G -->|No| H[No Transport]\n    G -->|Yes| I[Pi-H+ Cotransport]\n    I --> J[Cytoplasmic Pi]\n    \n    %% Low Pi - Pst System\n    D --> K[PHO Regulon Induction]\n    K --> L[PhoR/PhoB Activation]\n    L --> M[pstSCAB Operon Expression]\n    M --> N[Pst System Components]\n    \n    %% Pst System Assembly\n    N --> O{AND: PstS + PstCAB<br/>All Present?}\n    O -->|No| P[Transport Fails]\n    O -->|Yes| Q[Functional Pst Complex]\n    \n    %% PstS Binding Protein\n    Q --> R[PstS Periplasmic Protein]\n    A --> R\n    R --> S[PstS Binds Pi]\n    S --> T[PstS-Pi Complex]\n    \n    %% ABC Transporter\n    T --> U[PstS Docks with PstCAB]\n    U --> V{AND: PstA + PstC<br/>Membrane Pore?}\n    V -->|No| P\n    V -->|Yes| W[Pi Transfer to Transporter]\n    \n    W --> X{AND: PstB ATPase<br/>AND ATP?}\n    X -->|No| P\n    X -->|Yes| Y[ATP Hydrolysis]\n    Y --> Z[Conformational Change]\n    Z --> AA[Pi Transported]\n    AA --> J\n    \n    %% PhoU Regulation\n    J --> AB[Intracellular Pi]\n    AB --> AC{OR: Pi<br/>Level?}\n    AC -->|High| AD[Pi Binds PhoU]\n    AC -->|Low| AE[PhoU Free]\n    \n    AD --> AF[PhoU-Pi Complex]\n    AF --> AG[PhoU Interacts with PstB]\n    AG --> AH[/PhoU Inhibits PhoR/]\n    AH --> AI[\\PhoR Kinase Inactive/]\n    AI --> AJ[/PhoB Not Phosphorylated/]\n    AJ --> AK[PHO Regulon OFF]\n    \n    %% Low Pi - PhoR Activation\n    AE --> AL[/No PhoU Inhibition/]\n    AL --> AM[PhoR Autophosphorylation]\n    AM --> AN[PhoR~P Formation]\n    AN --> AO[Phosphotransfer to PhoB]\n    AO --> AP[PhoB~P Active]\n    \n    %% PHO Regulon Activation\n    AP --> AQ[PhoB~P Binds Pho Boxes]\n    AQ --> AR{OR: Which PHO<br/>Gene?}\n    AR -->|pstSCAB| AS[High-Affinity Transporter]\n    AR -->|phoA| AT[Alkaline Phosphatase]\n    AR -->|ugpBAEC| AU[Glycerol-3-P Transporter]\n    AR -->|phnCDE| AV[Phosphonate Utilization]\n    \n    AS --> M\n    \n    %% Alternative Pi Sources\n    AT --> AW[PhoA Secreted]\n    AW --> AX[Cleaves Organic Phosphates]\n    AX --> AY[Pi Released]\n    AY --> A\n    \n    AU --> AZ[Import Glycerol-3-Phosphate]\n    AZ --> BA[GlpQ Cleaves G3P]\n    BA --> BB[Glycerol + Pi]\n    BB --> J\n    \n    AV --> BC[Phosphonate ABC Transporter]\n    BC --> BD[C-P Lyase]\n    BD --> BE[Phosphonate \u2192 Pi]\n    BE --> J\n    \n    %% Phosphate Utilization\n    J --> BF{OR: Pi<br/>Use?}\n    BF -->|Nucleotides| BG[ATP/GTP/CTP/UTP Synthesis]\n    BF -->|Phospholipids| BH[Membrane Biosynthesis]\n    BF -->|DNA/RNA| BI[Nucleic Acid Synthesis]\n    BF -->|Phosphoproteins| BJ(\\1)\n    \n    BG --> BK([Energy/Metabolism])\n    BH --> BL([Membrane Growth])\n    BI --> BM([Replication/Transcription])\n    BJ --> BN((\\1))\n    \n    H --> BO([Pi Starvation])\n    P --> BO\n    AK --> BP((\\1))\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style B fill:#ffd600,color:#fff\n    style A fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill:#51cf66,color:#fff\n    style F fill:#b3e5fc,color:#000\n    style G fill:#7950f2,color:#fff\n    style H fill:#42a5f5,color:#fff\n    style I fill:#42a5f5,color:#fff\n    style J fill:#b3e5fc,color:#000\n    style K fill:#b3e5fc,color:#000\n    style L fill:#42a5f5,color:#fff\n    style M fill:#b3e5fc,color:#000\n    style N fill:#b3e5fc,color:#000\n    style O fill:#7950f2,color:#fff\n    style P fill:#42a5f5,color:#fff\n    style Q fill:#b3e5fc,color:#000\n    style R fill:#ffa726,color:#fff\n    style S fill:#b3e5fc,color:#000\n    style T fill:#b3e5fc,color:#000\n    style U fill:#b3e5fc,color:#000\n    style V fill:#7950f2,color:#fff\n    style W fill:#42a5f5,color:#fff\n    style X fill:#7950f2,color:#fff\n    style Y fill:#42a5f5,color:#fff\n    style Z fill:#b3e5fc,color:#000\n    style AA fill:#42a5f5,color:#fff\n    style AB fill:#000000,color:#fff\n    style AC fill:#ffd600,color:#fff\n    style AD fill:#b3e5fc,color:#000\n    style AE fill:#b3e5fc,color:#000\n    style AF fill:#b3e5fc,color:#000\n    style AG fill:#b3e5fc,color:#000\n    style AH fill:#e74c3c,color:#fff\n    style AI fill:#e74c3c,color:#fff\n    style AJ fill:#e74c3c,color:#fff\n    style AK fill:#b3e5fc,color:#000\n    style AL fill:#e74c3c,color:#fff\n    style AM fill:#42a5f5,color:#fff\n    style AN fill:#b3e5fc,color:#000\n    style AO fill:#b3e5fc,color:#000\n    style AP fill:#b3e5fc,color:#000\n    style AQ fill:#b3e5fc,color:#000\n    style AR fill:#ffd600,color:#fff\n    style AS fill:#42a5f5,color:#fff\n    style AT fill:#42a5f5,color:#fff\n    style AU fill:#42a5f5,color:#fff\n    style AV fill:#b3e5fc,color:#000\n    style AW fill:#b3e5fc,color:#000\n    style AX fill:#b3e5fc,color:#000\n    style AY fill:#b3e5fc,color:#000\n    style AZ fill:#42a5f5,color:#fff\n    style BA fill:#b3e5fc,color:#000\n    style BB fill:#b3e5fc,color:#000\n    style BC fill:#42a5f5,color:#fff\n    style BD fill:#b3e5fc,color:#000\n    style BE fill:#b3e5fc,color:#000\n    style BF fill:#ffd600,color:#fff\n    style BG fill:#42a5f5,color:#fff\n    style BH fill:#42a5f5,color:#fff\n    style BI fill:#42a5f5,color:#fff\n    style BJ fill:#51cf66,color:#fff\n    style BK fill:#000000,color:#fff\n    style BL fill:#000000,color:#fff\n    style BM fill:#42a5f5,color:#fff\n    style BN fill:#b3e5fc,color:#000\n    style BO fill:#51cf66,color:#fff\n    style BP fill:#000000,color:#fff",
