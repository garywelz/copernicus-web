    "stringent response",
    "ppGpp",
    "pppGpp",
    "RelA",
    "SpoT",
    "alarmone",
    "amino acid starvation",
    "rRNA regulation",
    "DksA",
    "global regulation",
    "growth control",
    "stress response"
  ],
  "lastUpdated": "2025-10-08",
  "logicGates": {
    "and": 2,
    "not": 1,
    "or": 2
  },
  "mermaid": "graph TD\n    %% Amino Acid Starvation Input\n    A[Amino Acid Limitation] --> B[Reduced Charged tRNA Pool]\n    C[Translation Stress] --> B\n    \n    %% tRNA Charging Imbalance\n    B --> D[Increased Uncharged tRNA]\n    D --> E[tRNA Charging Failure]\n    E --> F[Ribosome Stalling]\n    \n    %% Decision: Uncharged tRNA Present?\n    F --> G{Uncharged tRNA<br/>at A-site?}\n    \n    %% AND Gate: RelA Activation\n    G -->|Yes| ANDGATE1{Uncharged tRNA AND<br/>Ribosome Stalled?}\n    H[Ribosomal A-site] --> ANDGATE1\n    \n    %% RelA Activation\n    ANDGATE1 -->|Yes| I[RelA Binds Ribosome]\n    I --> J[RelA Conformational Change]\n    J --> K[RelA Synthetase Activation]\n    \n    %% (p)ppGpp Synthesis\n    K --> L[ATP Substrate Binding]\n    L --> M[GTP/GDP Substrate Binding]\n    M --> N[Phosphotransfer Reaction]\n    N --> O[pppGpp Synthesis]\n    N --> P[ppGpp Synthesis]\n    O --> Q[ppGpp/pppGpp Accumulation]\n    P --> Q\n    \n    %% Decision: ppGpp Levels\n    Q --> R{High ppGpp?}\n    \n    %% AND Gate: RNAP Regulation\n    R -->|Yes| ANDGATE2{ppGpp AND<br/>DksA Present?}\n    S[DksA Cofactor] --> ANDGATE2\n    \n    %% RNAP-ppGpp Complex\n    ANDGATE2 -->|Yes| T[ppGpp Binds RNAP]\n    T --> U[DksA Binds RNAP]\n    U --> V[RNAP Conformational Change]\n    \n    %% Stable RNA Repression\n    V --> W[rRNA Promoter Destabilization]\n    V --> X[tRNA Promoter Destabilization]\n    W --> Y[Reduced rRNA Transcription]\n    X --> Z[Reduced tRNA Transcription]\n    Y --> AA[Decreased Ribosome Synthesis]\n    Z --> AB[Decreased Translation Capacity]\n    AA --> AC[Growth Slowdown]\n    AB --> AC\n    \n    %% Amino Acid Biosynthesis Activation\n    V --> AD[Amino Acid Operon Activation]\n    AD --> AE[trp Operon Induction]\n    AD --> AF[his Operon Induction]\n    AD --> AG[ile Operon Induction]\n    AE --> AH[Tryptophan Biosynthesis]\n    AF --> AI[Histidine Biosynthesis]\n    AG --> AJ[Isoleucine Biosynthesis]\n    \n    %% Stress Gene Activation\n    V --> AK[Stress Response Gene Activation]\n    AK --> AL[rpoS Induction]\n    AK --> AM[Stationary Phase Genes]\n    AL --> AN[\u03c3S Alternative Sigma Factor]\n    AN --> AO[General Stress Response]\n    AM --> AP[Metabolic Adaptation]\n    \n    %% Amino Acid Pool Restoration\n    AH --> AQ[Amino Acid Pool Increase]\n    AI --> AQ\n    AJ --> AQ\n    AQ --> AR[tRNA Charging Restored]\n    AR --> AS[Translation Resumes]\n    \n    %% ppGpp Degradation\n    AS --> AT[RelA Dissociates from Ribosome]\n    AT --> AU[SpoT Hydrolase Activity]\n    AU --> AV[/ppGpp Degradation/]\n    AV --> AW[Basal ppGpp Levels]\n    AW --> AX[rRNA Transcription Restored]\n    AX --> AY[Growth Resumption]\n    \n    %% Normal Growth Path\n    G -->|No| AZ[Normal tRNA Charging]\n    AZ --> BA[Low ppGpp Levels]\n    BA --> BB[High rRNA/tRNA Transcription]\n    BB --> BC[Rapid Ribosome Synthesis]\n    BC --> BD[Fast Growth]\n    \n    %% System Outputs\n    AC --> BE[Survival Mode]\n    AO --> BF[Stress Resistance]\n    AP --> BG[Metabolic Remodeling]\n    AY --> BH[Growth Recovery]\n    BD --> BI[Optimal Growth]\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style A fill:#51cf66,color:#fff\n    style B fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill:#51cf66,color:#fff\n    style F fill:#b3e5fc,color:#000\n    style G fill:#ffd600,color:#fff\n    style ANDGATE1 fill:#7950f2,color:#fff\n    style H fill:#b3e5fc,color:#000\n    style I fill:#b3e5fc,color:#000\n    style J fill:#b3e5fc,color:#000\n    style K fill:#ffa726,color:#fff\n    style L fill:#42a5f5,color:#fff\n    style M fill:#42a5f5,color:#fff\n    style N fill:#b3e5fc,color:#000\n    style O fill:#42a5f5,color:#fff\n    style P fill:#42a5f5,color:#fff\n    style Q fill:#b3e5fc,color:#000\n    style R fill:#ffd600,color:#fff\n    style ANDGATE2 fill:#7950f2,color:#fff\n    style S fill:#ffa726,color:#fff\n    style T fill:#b3e5fc,color:#000\n    style U fill:#b3e5fc,color:#000\n    style V fill:#b3e5fc,color:#000\n    style W fill:#b3e5fc,color:#000\n    style X fill:#b3e5fc,color:#000\n    style Y fill:#42a5f5,color:#fff\n    style Z fill:#42a5f5,color:#fff\n    style AA fill:#42a5f5,color:#fff\n    style AB fill:#42a5f5,color:#fff\n    style AC fill:#000000,color:#fff\n    style AD fill:#42a5f5,color:#fff\n    style AE fill:#b3e5fc,color:#000\n    style AF fill:#b3e5fc,color:#000\n    style AG fill:#b3e5fc,color:#000\n    style AH fill:#42a5f5,color:#fff\n    style AI fill:#42a5f5,color:#fff\n    style AJ fill:#42a5f5,color:#fff\n    style AK fill:#51cf66,color:#fff\n    style AL fill:#b3e5fc,color:#000\n    style AM fill:#b3e5fc,color:#000\n    style AN fill:#ffa726,color:#fff\n    style AO fill:#51cf66,color:#fff\n    style AP fill:#000000,color:#fff\n    style AQ fill:#b3e5fc,color:#000\n    style AR fill:#b3e5fc,color:#000\n    style AS fill:#42a5f5,color:#fff\n    style AT fill:#b3e5fc,color:#000\n    style AU fill:#42a5f5,color:#fff\n    style AV fill:#e74c3c,color:#fff\n    style AW fill:#b3e5fc,color:#000\n    style AX fill:#42a5f5,color:#fff\n    style AY fill:#000000,color:#fff\n    style AZ fill:#b3e5fc,color:#000\n    style BA fill:#b3e5fc,color:#000\n    style BB fill:#42a5f5,color:#fff\n    style BC fill:#42a5f5,color:#fff\n    style BD fill:#000000,color:#fff\n    style BE fill:#000000,color:#fff\n    style BF fill:#51cf66,color:#fff\n    style BG fill:#b3e5fc,color:#000\n    style BH fill:#000000,color:#fff\n    style BI fill:#000000,color:#fff",
  "name": "Stringent Response and ppGpp-Mediated Growth Control",
  "notGates": 1,
  "notes": "This flowchart represents the stringent response system with 40 unique nodes (A-BI). Contains 2 OR logic gates (uncharged tRNA detection, ppGpp level assessment) and 2 AND gates (RelA activation requires both uncharged tRNA AND ribosome stalling; RNAP regulation requires both ppGpp AND DksA). The system demonstrates global metabolic reprogramming affecting ~500 genes, coordinated repression of growth-related genes (rRNA/tRNA) with activation of biosynthetic and stress genes. Includes both rapid response (RelA synthesis) and recovery (SpoT degradation). All mechanisms validated against genetic, biochemical, and structural studies.",
  "organism": "E. coli",
  "relatedProcesses": [
    "ecoli_transcription_regulation",
    "ecoli_catabolite_repression",
    "ecoli_heat_shock_response"
  ],
  "scientificAccuracy": "This flowchart is based on over 50 years of research on the stringent response, beginning with the discovery of 'magic spot' nucleotides. The RelA-mediated (p)ppGpp synthesis mechanism and its direct binding to RNA polymerase are thoroughly characterized. All regulatory mechanisms have been validated through genetic, biochemical, and structural studies including recent crystal structures of RNAP-(p)ppGpp complexes.",
