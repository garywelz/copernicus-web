  "mermaid": "graph TD\n    %% Central Metabolism Sources\n    A(\\1) --> B[3-Phosphoglycerate]\n    A --> C[Phosphoenolpyruvate PEP]\n    A --> D(\\1)\n    E[TCA Cycle] --> F[\u03b1-Ketoglutarate]\n    E --> G(\\1)\n    H[Pentose Phosphate] --> I[Ribose-5-Phosphate]\n    I --> J(\\1)\n    H --> K[Erythrose-4-Phosphate E4P]\n    \n    %% OR Gate 1: Which Amino Acid Family?\n    L[Amino Acid Biosynthesis] --> M{OR: Which<br/>Precursor?}\n    M -->|\u03b1-KG| N[Glutamate Family]\n    M -->|OAA| O[Aspartate Family]\n    M -->|3-PG| P[Serine Family]\n    M -->|PEP+E4P| Q{Aromatic: PEP AND E4P}\n    M -->|Pyruvate| R[Pyruvate Family]\n    M -->|PRPP| S(\\1)\n    \n    %% Glutamate Family\n    F --> N\n    N --> T[\"GltA: \u03b1-KG + NH3 \u2192 Glutamate\"]\n    T --> U[Glutamate Central Hub]\n    \n    U --> V{OR: Glu<br/>Branch?}\n    V -->|GlnA| W[Glu + NH3 \u2192 Glutamine]\n    V -->|ProABC| X[Glu \u2192 Proline 5 steps]\n    V -->|ArgABCDEFGH| Y[Glu \u2192 Arginine 8 steps]\n    \n    W --> Z(\\1)\n    X --> AA(\\1)\n    Y --> AB(\\1)\n    \n    %% Aspartate Family\n    G --> O\n    O --> AC[\"AspC: OAA + Glu \u2192 Aspartate\"]\n    AC --> AD[Aspartate Hub]\n    \n    AD --> AE{OR: Asp<br/>Branch?}\n    AE -->|AsnAB| AF[Asp + Gln \u2192 Asparagine]\n    AE -->|MetLABCE| AG[Asp \u2192 Methionine via Homoserine]\n    AE -->|ThrABC| AH[Asp \u2192 Threonine]\n    AE -->|LysC-DapF| AI[Asp \u2192 Lysine via DAP]\n    \n    AF --> AJ(\\1)\n    AG --> AK(\\1)\n    AH --> AL(\\1)\n    AL --> AL_OR{Thr Path?}\n    AL_OR -->|To Ile| AM[\"IlvA: Thr \u2192 Isoleucine\"]\n    AM --> AN(\\1)\n    AI --> AO(\\1)\n    \n    %% Serine Family\n    B --> P\n    P --> AP[\"SerA: 3-PG \u2192 3-Phosphohydroxypyruvate\"]\n    AP --> AQ[\"SerC: Transamination\"]\n    AQ --> AR[\"SerB: Dephosphorylation\"]\n    AR --> AS(\\1)\n    \n    AS --> AT{OR: Ser<br/>Branch?}\n    AT -->|GlyA| AU[Ser \u2192 Glycine + C1 unit]\n    AT -->|CysE+CysK| AV[Ser \u2192 Cysteine]\n    \n    AU --> AW(\\1)\n    AV --> AX(\\1)\n    \n    %% Aromatic Family\n    C --> Q\n    K --> Q\n    Q --> AY[\"AroABCDEF: Shikimate Pathway\"]\n    AY --> AZ[Chorismate Common Intermediate]\n    \n    AZ --> BA{OR: Aromatic<br/>Branch?}\n    BA -->|PheA+TyrA| BB[Phe/Tyr Pathway]\n    BA -->|TrpABCDE| BC[Trp Pathway 5 steps]\n    \n    BB --> BD{OR: Prephenate<br/>Branch?}\n    BD -->|PheA| BE[Prephenate \u2192 Phenylalanine]\n    BD -->|TyrA| BF[Prephenate \u2192 Tyrosine]\n    \n    BE --> BG[Phenylalanine]\n    BF --> BH(\\1)\n    BC --> BI(\\1)\n    \n    %% Pyruvate Family\n    D --> R\n    R --> BJ[Pyruvate Hub]\n    \n    BJ --> BK{OR: Pyr<br/>Branch?}\n    BK -->|AlaA| BL[Pyr + Glu \u2192 Alanine]\n    BK -->|IlvBCDE| BM[Pyr \u2192 Valine 4 steps]\n    \n    BL --> BN(\\1)\n    BM --> BO(\\1)\n    BO --> BO_OR{Val Path?}\n    BO_OR -->|To Leu| BP[\"LeuABCD: Val \u2192 Leucine\"]\n    BP --> BQ(\\1)\n    \n    %% Histidine Pathway\n    J --> S\n    S --> BR[\"HisABCDEFGH: 10 steps\"]\n    BR --> BS(\\1)\n    \n    %% Feedback Regulation\n    Z --> BT{High Gln?}\n    BT -->|Yes| BU[GlnA Feedback Active]\n    BU --> BV[/Gln Synthesis Reduced/]\n    \n    AB --> BW[ArgR Repressor Protein]\n    BW --> BX[/arg Operon Repression/]\n    \n    BI --> BY[TrpR Repressor Protein]\n    BY --> BZ[/trp Operon Repression/]\n    \n    %% Outputs\n    BN --> CA([20 Amino Acids])\n    Z --> CA\n    AA --> CA\n    AB --> CA\n    AJ --> CA\n    AK --> CA\n    AL --> CA\n    AN --> CA\n    AO --> CA\n    AW --> CA\n    AX --> CA\n    BG --> CA\n    BH --> CA\n    BI --> CA\n    BO --> CA\n    BQ --> CA\n    BS --> CA\n    \n    CA --> CB[Protein Synthesis]\n    CB --> CC([Cell Growth])\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style A fill:#51cf66,color:#fff\n    style B fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill: