    "and": 2,
    "not": 5,
    "or": 5
  },
  "mermaid": "graph TD\n    %% Environmental Signal\n    A[Environmental Change] --> B{OR: Which<br/>Signal?}\n    B -->|Osmolarity| C(\\1)\n    B -->|Phosphate| D(\\1)\n    B -->|Nitrogen| E(\\1)\n    B -->|Acid| F(\\1)\n    B -->|Other| G[30+ TCS Systems]\n    \n    %% EnvZ-OmpR Paradigm\n    C --> H[Osmolarity Change]\n    H --> I{OR: Osmolarity<br/>Level?}\n    I -->|High| J[High Osmolarity]\n    I -->|Low| K[Low Osmolarity]\n    \n    %% EnvZ Sensor Kinase\n    J --> L[EnvZ Periplasmic Domain]\n    K --> L\n    L --> M[Signal Detection]\n    M --> N[Conformational Change]\n    N --> O[EnvZ Cytoplasmic Kinase Domain]\n    \n    %% Autophosphorylation\n    O --> P{AND: ATP<br/>Available?}\n    P -->|No| Q[No Phosphorylation]\n    P -->|Yes| R[EnvZ Homodimer]\n    \n    R --> S[Trans-autophosphorylation]\n    S --> T[His243 Phosphorylation]\n    T --> U[EnvZ~P Formation]\n    \n    %% Phosphotransfer\n    U --> V[OmpR Response Regulator]\n    V --> W{AND: EnvZ~P<br/>AND OmpR?}\n    W -->|No| Q\n    W -->|Yes| X[Phosphotransfer]\n    \n    X --> Y[His243~P \u2192 Asp55]\n    Y --> Z[OmpR~P Formation]\n    \n    %% OmpR~P DNA Binding\n    Z --> AA[OmpR~P Dimerization]\n    AA --> AB[Enhanced DNA Binding]\n    AB --> AC[OmpR Binding Sites]\n    \n    %% Differential Gene Regulation\n    J --> AD[High Osmolarity]\n    AD --> AE[High OmpR~P]\n    AE --> AF{OR: ompF<br/>or ompC?}\n    AF -->|ompF| AG[\\ompF Repressed/]\n    AF -->|ompC| AH[ompC Activated]\n    \n    K --> AI[Low Osmolarity]\n    AI --> AJ[Low OmpR~P]\n    AJ --> AK{OR: ompF<br/>or ompC?}\n    AK -->|ompF| AL[ompF Activated]\n    AK -->|ompC| AM[\\ompC Repressed/]\n    \n    %% Porin Expression\n    AH --> AN[OmpC Porin Small Pore]\n    AN --> AO[Restricts Solute Entry]\n    AO --> AP([High Osmolarity Adaptation])\n    \n    AL --> AQ[OmpF Porin Large Pore]\n    AQ --> AR[Facilitates Nutrient Uptake]\n    AR --> AS([Low Osmolarity Adaptation])\n    \n    %% Phosphatase Activity\n    Z --> AT[EnvZ Phosphatase]\n    AT --> AU[EnvZ Dephosphorylates OmpR~P]\n    AU --> AV[\\OmpR Inactive/]\n    AV --> AW[/Signal Termination/]\n    \n    %% Other TCS Examples\n    D --> AX[Phosphate Starvation]\n    E --> AY[Nitrogen Limitation]\n    F --> AZ[Acid Stress]\n    \n    AX --> BA[PhoB~P Activates PHO Regulon]\n    AY --> BB[NtrC~P Activates Nitrogen Genes]\n    AZ --> BC[EvgA~P Activates Acid Resistance]\n    \n    BA --> BD([Phosphate Scavenging])\n    BB --> BE([Nitrogen Assimilation])\n    BC --> BF([Acid Survival])\n    \n    %% Cross-Regulation\n    Z --> BG{OR: Other<br/>Targets?}\n    BG -->|micF| BH[micF Antisense RNA]\n    BG -->|bolA| BI[bolA Morphogene]\n    \n    BH --> BJ[/Represses OmpF Translation/]\n    BI --> BK[Cell Shape Changes]\n    \n    BJ --> AP\n    BK --> BL([Stress Morphology])\n    \n    Q --> BM([No Response])\n    AG --> BN([ompF OFF])\n    AM --> BO([ompC OFF])\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style B fill:#ffd600,color:#fff\n    style A fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill:#51cf66,color:#fff\n    style F fill:#b3e5fc,color:#000\n    style G fill:#b3e5fc,color:#000\n    style H fill:#b3e5fc,color:#000\n    style I fill:#ffd600,color:#fff\n    style J fill:#b3e5fc,color:#000\n    style K fill:#b3e5fc,color:#000\n    style L fill:#b3e5fc,color:#000\n    style M fill:#51cf66,color:#fff\n    style N fill:#b3e5fc,color:#000\n    style O fill:#42a5f5,color:#fff\n    style P fill:#7950f2,color:#fff\n    style Q fill:#42a5f5,color:#fff\n    style R fill:#b3e5fc,color:#000\n    style S fill:#42a5f5,color:#fff\n    style T fill:#42a5f5,color:#fff\n    style U fill:#b3e5fc,color:#000\n    style V fill:#000000,color:#fff\n    style W fill:#7950f2,color:#fff\n    style X fill:#b3e5fc,color:#000\n    style Y fill:#b3e5fc,color:#000\n    style Z fill:#b3e5fc,color:#000\n    style AA fill:#b3e5fc,color:#000\n    style AB fill:#42a5f5,color:#fff\n    style AC fill:#42a5f5,color:#fff\n    style AD fill:#b3e5fc,color:#000\n    style AE fill:#b3e5fc,color:#000\n    style AF fill:#ffd600,color:#fff\n    style AG fill:#e74c3c,color:#fff\n    style AH fill:#b3e5fc,color:#000\n    style AI fill:#b3e5fc,color:#000\n    style AJ fill:#b3e5fc,color:#000\n    style AK fill:#ffd600,color:#fff\n    style AL fill:#b3e5fc,color:#000\n    style AM fill:#e74c3c,color:#fff\n    style AN fill:#b3e5fc,color:#000\n    style AO fill:#b3e5fc,color:#000\n    style AP fill:#000000,color:#fff\n    style AQ fill:#b3e5fc,color:#000\n    style AR fill:#51cf66,color:#fff\n    style AS fill:#000000,color:#fff\n    style AT fill:#42a5f5,color:#fff\n    style AU fill:#b3e5fc,color:#000\n    style AV fill:#e74c3c,color:#fff\n    style AW fill:#e74c3c,color:#fff\n    style AX fill:#51cf66,color:#fff\n    style AY fill:#51cf66,color:#fff\n    style AZ fill:#51cf66,color:#fff\n    style BA fill:#b3e5fc,color:#000\n    style BB fill:#b3e5fc,color:#000\n    style BC fill:#b3e5fc,color:#000\n    style BD fill:#b3e5fc,color:#000\n    style BE fill:#b3e5fc,color:#000\n    style BF fill:#000000,color:#fff\n    style BG fill:#ffd600,color:#fff\n    style BH fill:#b3e5fc,color:#000\n    style BI fill:#b3e5fc,color:#000\n    style BJ fill:#e74c3c,color:#fff\n    style BK fill:#000000,color:#fff\n    style BL fill:#51cf66,color:#fff\n    style BM fill:#000000,color:#fff\n    style BN fill:#b3e5fc,color:#000\n    style BO fill:#b3e5fc,color:#000",
