  "mermaid": "graph TD\n    Start([TOR Signaling]) --> A1{Nutrient status?}\n    \n    A1 -->|Amino acids present| A2[Amino acid sensing pathway]\n    A1 -->|Nitrogen present| A3[Nitrogen sensing pathway]\n    A1 -->|Glucose present| A4[Glucose sensing pathway]\n    \n    A2 --> A5[EGO complex Gtr1/Gtr2 GTPases]\n    A5 --> A6{Amino acids available?}\n    A6 -->|Yes| A7[Gtr1-GTP, Gtr2-GDP state]\n    A6 -->|No| A8[Gtr1-GDP, Gtr2-GTP state]\n    \n    A7 --> A9[EGO complex recruits TORC1 to vacuole]\n    A8 --> A10[\\TORC1 not recruited - inactive/]\n    \n    A3 --> A11[Glutamine synthetase Gln3]\n    A11 --> A12{Nitrogen quality?}\n    A12 -->|Good nitrogen NH4+| A13[\\Gln3 phosphorylated and inhibited/]\n    A12 -->|Poor nitrogen| A14[Gln3 active]\n    \n    A4 --> A15[Glucose activates PKA pathway]\n    A15 --> A16[Cross-talk with TOR]\n    \n    A9 --> A17[TORC1 complex at vacuole membrane]\n    A17 --> A18{TORC1 components assembled?}\n    A18 -->|Tor1 or Tor2 + Kog1 + Lst8 + Tco89| A19[Active TORC1 complex]\n    A18 -->|Missing component| Wait1[Wait for assembly]\n    Wait1 --> A18\n    \n    A19 --> A20{Rapamycin present?}\n    A20 -->|Yes - drug inhibition| A21[Rapamycin binds FKBP12 Fpr1]\n    A20 -->|No - normal| A22[TORC1 active]\n    \n    A21 --> A23[Rapamycin-FKBP12 binds Tor FRB domain]\n    A23 --> A24[\\TORC1 inhibited allosterically/]\n    \n    A22 --> A25[TORC1 kinase activity]\n    A25 --> A26[Multiple downstream targets]\n    \n    A26 --> A27[\"Target 1: Sch9 kinase AGC family\"]\n    A27 --> A28{TORC1 phosphorylates Sch9?}\n    A28 -->|Yes - nutrients| A29[Sch9 phosphorylated and active]\n    A28 -->|No - starvation| A30[\\Sch9 inactive/]\n    \n    A29 --> A31[Sch9 promotes translation initiation]\n    A31 --> A32[Phosphorylates ribosomal protein S6]\n    A32 --> A33[Ribosome biogenesis activated]\n    \n    A29 --> A34[/Sch9 inhibits stress responses/]\n    A34 --> A35[Msn2/4 transcription factors excluded from nucleus]\n    \n    A26 --> A36[\"Target 2: Tap42-PP2A phosphatase complex\"]\n    A36 --> A37[TORC1 phosphorylates Tap42]\n    A37 --> A38[Tap42~P binds Sit4 and PP2A phosphatases]\n    A38 --> A39[\\Phosphatases inhibited when bound to Tap42~P/]\n    \n    A39 --> A40{Result of phosphatase inhibition}\n    A40 -->|Substrate phosphorylation maintained| A41[Gln3 stays phosphorylated]\n    A41 --> A42[/Nitrogen catabolite repression active/]\n    \n    A26 --> A43[\"Target 3: Transcription factors\"]\n    A43 --> A44[TORC1 regulates Gln3 Gat1 Rtg1/3]\n    A44 --> A45[Ribosomal protein genes activated]\n    A45 --> A46[tRNA synthesis genes activated]\n    \n    A46 --> A47[Translation capacity increases]\n    \n    A26 --> A48[\"/Target 4: Autophagy repression/\"]\n    A48 --> A49[TORC1 phosphorylates Atg13]\n    A49 --> A50[/Atg13~P cannot activate Atg1 kinase/]\n    A50 --> A51[\\Autophagy blocked/]\n    \n    A33 --> A52[Anabolic outputs]\n    A47 --> A52\n    A51 --> A52\n    \n    A52 --> A53[Cell growth promoted]\n    A53 --> A54[Protein synthesis high]\n    A54 --> A55[Ribosome production high]\n    A55 --> A56[Nutrient import active]\n    \n    A56 --> End1([Growth state])\n    \n    A10 --> A57[\\TORC1 inactive - starvation response/]\n    A24 --> A57\n    A30 --> A57\n    \n    A57 --> A58[/Tap42 not phosphorylated/]\n    A58 --> A59[Sit4 PP2A phosphatases released and active]\n    \n    A59 --> A60[Dephosphorylation of TORC1 substrates]\n    A60 --> A61[Gln3 Gat1 dephosphorylated]\n    A61 --> A62[Gln3/Gat1 enter nucleus]\n    A62 --> A63[/Nitrogen catabolite repression relieved/]\n    A63 --> A64[NCR genes expressed - use poor nitrogen]\n    \n    A59 --> A65[Msn2/Msn4 dephosphorylated]\n    A65 --> A66[Msn2/4 enter nucleus]\n    A66 --> A67[STRE stress genes activated]\n    A67 --> A68[Stress protection genes expressed]\n    \n    A57 --> A69[Atg13 dephosphorylated]\n    A69 --> A70[Atg13 activates Atg1 kinase]\n    A70 --> A71[Autophagy initiated]\n    A71 --> A72[/Bulk protein degradation/]\n    A72 --> A73[Amino acids recycled]\n    \n    A57 --> A74[Gcn2 kinase activated]\n    A74 --> A75[eIF2\u03b1 phosphorylated]\n    A75 --> A76[\\General translation repressed/]\n    A76 --> A77[But Gcn4 translation activated paradoxically]\n    A77 --> A78[Gcn4 transcription factor active]\n    A78 --> A79[Amino acid biosynthesis genes induced]\n    \n    A64 --> A80[Catabolic outputs]\n    A68 --> A80\n    A73 --> A80\n    A79 --> A80\n    \n    A80 --> A81[Cell growth arrested]\n    A81 --> A82[Autophagy active - protein turnover]\n    A82 --> A83[Stress resistance high]\n    A83 --> A84[Amino acid synthesis activated]\n    \n    A84 --> End2([Starvation/stress state])\n    \n    A13 --> A85[TORC1 and PKA coordinate]\n    A16 --> A85\n    A85 --> A86[Growth only when both nutrients AND glucose]\n    A86 --> A87{Both pathways active?}\n    A87 -->|Yes| A22\n    A87 -->|No| A57\n    \n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style A1 fill:#ffd600,color:#fff\n    style A2 fill:#b3e5fc,color:#000\n    style A3 fill:#b3e5fc,color:#000\n    style A4 fill:#b3e5fc,color:#000\n    style A5 fill:#b3e5fc,color:#000\n    style A6 fill:#ffd600,color:#fff\n    style A7 fill:#b3e5fc,color:#000\n    style A8 fill:#b3e5fc,color:#000\n    style A9 fill:#b3e5fc,color:#000\n    style A10 fill:#e74c3c,color:#fff\n    style A11 fill:#ffa726,color:#fff\n    style A12 fill:#ffd600,color:#fff\n    style A13 fill:#e74c3c,color:#fff\n    style A14 fill:#b3e5fc,color:#000\n    style A15 fill:#b3e5fc,color:#000\n    style A16 fill:#b3e5fc,color:#000\n    style A17 fill:#b3e5fc,color:#000\n    style A18 fill:#ffd600,color:#fff\n    style A19 fill:#b3e5fc,color:#000\n    style A20 fill:#ffd600,color:#fff\n    style A21 fill:#b3e5fc,color:#000\n    style A22 fill:#b3e5fc,color:#000\n    style A23 fill:#b3e5fc,color:#000\n    style A24 fill:#e74c3c,color:#fff\n    style A25 fill:#42a5f5,col