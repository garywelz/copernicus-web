    "and": 2,
    "not": 5,
    "or": 2
  },
  "mermaid": "graph TD\n    %% Heat Stress\n    A[Temperature Increase] --> B{OR: Stress<br/>Level?}\n    B -->|Normal 37\u00b0C| C(\\1)\n    B -->|Heat Shock >42\u00b0C| D[Protein Stress]\n    \n    %% Normal Conditions\n    C --> E[\u03c332 RpoH Basal Level]\n    E --> F[DnaK/DnaJ Chaperones Available]\n    F --> G[DnaK Binds \u03c332]\n    G --> H[DnaJ Stimulates ATPase]\n    H --> I[DnaK-ADP-\u03c332 Complex]\n    I --> J[GrpE Nucleotide Exchange]\n    J --> K[DnaK Releases \u03c332]\n    K --> L[FtsH Protease Access]\n    L --> M[/\u03c332 Degradation/]\n    M --> N[Low \u03c332 t1/2 ~1 min]\n    N --> O([Basal Heat Shock Genes])\n    \n    %% Heat Shock - Protein Misfolding\n    D --> P[Proteins Unfold]\n    P --> Q[Hydrophobic Residues Exposed]\n    Q --> R[Misfolded Protein Accumulation]\n    \n    %% Chaperone Titration\n    R --> S[DnaK/DnaJ Bind Misfolded Proteins]\n    S --> T[Chaperones Sequestered]\n    T --> U[/\u03c332 Not Bound by DnaK/]\n    U --> V[\u03c332 Stabilized]\n    V --> W[\u03c332 Accumulates]\n    \n    %% \u03c332-RNAP Complex\n    W --> X[\u03c332 Binds Core RNAP]\n    X --> Y{AND: \u03c332 + Core<br/>RNAP?}\n    Y -->|No| Z[/No Transcription/]\n    Y -->|Yes| AA[E\u03c332 Holoenzyme]\n    \n    %% Heat Shock Promoter Recognition\n    AA --> AB[E\u03c332 Recognizes Heat Shock Promoters]\n    AB --> AC[-35 CTTGAAA]\n    AC --> AD[-10 CCCCATNT]\n    AD --> AE[Heat Shock Gene Transcription]\n    \n    %% OR Gate: Which Heat Shock Gene?\n    AE --> AF{OR: Which<br/>Gene Class?}\n    AF -->|dnaK/dnaJ/grpE| AG[DnaK Chaperone System]\n    AF -->|groEL/groES| AH[GroEL Chaperonin System]\n    AF -->|clpB| AI[ClpB Disaggregase]\n    AF -->|lon/ftsH| AJ[ATP-Dependent Proteases]\n    AF -->|htpG| AK[HtpG Hsp90 Homolog]\n    AF -->|ibpAB| AL[Small Heat Shock Proteins]\n    \n    %% DnaK System Upregulation\n    AG --> AM[DnaK/DnaJ/GrpE Production]\n    AM --> AN[Enhanced Chaperone Capacity]\n    AN --> AO[Protein Refolding]\n    \n    %% GroEL System\n    AH --> AP[GroEL/ES Production]\n    AP --> AQ[GroEL Barrel Complex]\n    AQ --> AR[Anfinsen Cage]\n    AR --> AS[Substrate Encapsulation]\n    AS --> AT[ATP-Dependent Folding]\n    AT --> AO\n    \n    %% ClpB Disaggregase\n    AI --> AU[ClpB AAA+ ATPase]\n    AU --> AV[Aggregate Recognition]\n    AV --> AW{AND: ClpB + DnaK<br/>Cooperation?}\n    AW -->|No| AX[Aggregates Persist]\n    AW -->|Yes| AY[Aggregate Disassembly]\n    AY --> AZ[Proteins Extracted]\n    AZ --> AO\n    \n    %% Proteolytic Quality Control\n    AJ --> BA[Lon/FtsH Proteases]\n    BA --> BB[Recognize Misfolded Proteins]\n    BB --> BC[Irreversibly Damaged]\n    BC --> BD[/Protease Degradation/]\n    BD --> BE[Amino Acids Recycled]\n    \n    %% Negative Feedback\n    AM --> BF[Newly Synthesized DnaK]\n    BF --> BG[Excess Chaperone Capacity]\n    BG --> BH[DnaK Rebinds \u03c332]\n    BH --> BI[\u03c332 Destabilization]\n    BI --> BJ[/FtsH Degrades \u03c332/]\n    BJ --> BK[\u03c332 Levels Drop]\n    BK --> BL[Heat Shock Response OFF]\n    \n    %% Resolution\n    AO --> BM[Proteins Refolded]\n    BE --> BM\n    BM --> BN[Proteome Restored]\n    BN --> BO[Temperature Normalized]\n    BO --> BP((\\1))\n    \n    AX --> BQ[Inclusion Bodies]\n    BQ --> BR[Permanent Aggregates]\n    BR --> BS([Cell Death])\n    \n    Z --> BT([No Response])\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style B fill:#ffd600,color:#fff\n    style A fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill:#51cf66,color:#fff\n    style F fill:#b3e5fc,color:#000\n    style G fill:#b3e5fc,color:#000\n    style H fill:#b3e5fc,color:#000\n    style I fill:#b3e5fc,color:#000\n    style J fill:#b3e5fc,color:#000\n    style K fill:#b3e5fc,color:#000\n    style L fill:#42a5f5,color:#fff\n    style M fill:#e74c3c,color:#fff\n    style N fill:#b3e5fc,color:#000\n    style O fill:#51cf66,color:#fff\n    style P fill:#ffa726,color:#fff\n    style Q fill:#b3e5fc,color:#000\n    style R fill:#ffa726,color:#fff\n    style S fill:#ffa726,color:#fff\n    style T fill:#b3e5fc,color:#000\n    style U fill:#e74c3c,color:#fff\n    style V fill:#b3e5fc,color:#000\n    style W fill:#b3e5fc,color:#000\n    style X fill:#b3e5fc,color:#000\n    style Y fill:#7950f2,color:#fff\n    style Z fill:#e74c3c,color:#fff\n    style AA fill:#ffa726,color:#fff\n    style AB fill:#51cf66,color:#fff\n    style AC fill:#b3e5fc,color:#000\n    style AD fill:#b3e5fc,color:#000\n    style AE fill:#51cf66,color:#fff\n    style AF fill:#ffd600,color:#fff\n    style AG fill:#b3e5fc,color:#000\n    style AH fill:#b3e5fc,color:#000\n    style AI fill:#b3e5fc,color:#000\n    style AJ fill:#42a5f5,color:#fff\n    style AK fill:#b3e5fc,color:#000\n    style AL fill:#51cf66,color:#fff\n    style AM fill:#000000,color:#fff\n    style AN fill:#b3e5fc,color:#000\n    style AO fill:#ffa726,color:#fff\n    style AP fill:#000000,color:#fff\n    style AQ fill:#b3e5fc,color:#000\n    style AR fill:#b3e5fc,color:#000\n    style AS fill:#b3e5fc,color:#000\n    style AT fill:#b3e5fc,color:#000\n    style AU fill:#b3e5fc,color:#000\n    style AV fill:#b3e5fc,color:#000\n    style AW fill:#7950f2,color:#fff\n    style AX fill:#b3e5fc,color:#000\n    style AY fill:#42a5f5,color:#fff\n    style AZ fill:#ffa726,color:#fff\n    style BA fill:#42a5f5,color:#fff\n    style BB fill:#ffa726,color:#fff\n    style BC fill:#51cf66,color:#fff\n    style BD fill:#e74c3c,color:#fff\n    style BE fill:#b3e5fc,color:#000\n    style BF fill:#b3e5fc,color:#000\n    style BG fill:#b3e5fc,color:#000\n    style BH fill:#b3e5fc,color:#000\n    style BI fill:#b3e5fc,color:#000\n    style BJ fill:#e74c3c,color:#fff\n    style BK fill:#b3e5fc,color:#000\n    style BL fill:#51cf66,color:#fff\n    style BM fill:#ffa726,color:#fff\n    style BN fill:#b3e5fc,color:#000\n    style BO fill:#b3e5fc,color:#000\n    style BP fill:#b3e5fc,color:#000\n    style BQ fill:#b3e5fc,color:#000\n    style BR fill:#b3e5fc,color:#000\n    style BS fill:#000000,color:#fff\n    style BT fill:#000000,color:#fff",
