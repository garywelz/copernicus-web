    "and": 2,
    "not": 6,
    "or": 4
  },
  "mermaid": "graph TD\n    %% Environmental Signals and Inputs\n    A[Nutrient Limitation] --> B[Environmental Stress Signal]\n    C[High Cell Density] --> D[Quorum Sensing Signal]\n    E[Surface Contact] --> F[Surface Sensing Signal]\n    G[DNA Damage] --> H[SOS Response Signal]\n    I[Oxygen Limitation] --> J[Anaerobic Signal]\n    \n    %% OR Gate 1: Multiple Biofilm Triggers\n    B --> K{OR: Any Biofilm<br/>Inducing Signal?}\n    D --> K\n    F --> K\n    H --> K\n    J --> K\n    K -->|Yes - Signals Present| L[Kinase Phosphorylation Cascade]\n    K -->|No - No Signals| M[Maintain Planktonic State]\n    \n    %% Spo0A Phosphoryl Transfer\n    L --> N[KinA/KinB/KinC/KinD Autophosphorylation]\n    N --> O[Phosphotransfer to Spo0F]\n    O --> P[Spo0F~P Formation]\n    P --> Q[Spo0B Phosphotransferase]\n    Q --> R[Spo0A Phosphorylation]\n    R --> S[Spo0A~P Accumulation]\n    \n    %% OR Gate 2: Spo0A~P Threshold\n    S --> T{OR: Spo0A~P<br/>Above Threshold?}\n    T -->|Low - Below Threshold| M\n    T -->|High - Above Threshold| U[Biofilm Program Activation]\n    \n    %% SinR Repression Relief\n    U --> V[sinI Gene Transcription]\n    V --> W[SinI Protein Production]\n    W --> X[SinI Binds SinR]\n    X --> Y[/SinR Repressor Inactivated/]\n    \n    %% AND Gate 1: Matrix Gene Derepression\n    Y --> Z[\"\\{AND: SinR Inactive<br/>AND Spo0A~P High?/\"]}\n    S --> Z\n    Z -->|No| M\n    Z -->|Yes| AA[/Matrix Gene Derepression/]\n    \n    %% OR Gate 3: Which Matrix Operon?\n    AA --> AB{OR: Which Matrix<br/>Component?}\n    AB -->|EPS Route| AC[epsA-O Operon Transcription]\n    AB -->|TasA Route| AD[tasA Operon Transcription]\n    AB -->|Both Routes| AE[Both Operons Active]\n    \n    %% EPS Biosynthesis Pathway\n    AC --> AF[EpsA-O Proteins Produced]\n    AF --> AG[EpsA Glycosyltransferase]\n    AG --> AH[EpsB-E Sugar Synthesis]\n    AH --> AI[EpsF-O Export Complex]\n    AI --> AJ[Exopolysaccharide Synthesis]\n    AJ --> AK[EPS Secreted to Matrix]\n    \n    %% TasA Amyloid Pathway\n    AD --> AL[TasA Protein Synthesis]\n    AL --> AM[TapA Anchor Protein]\n    AM --> AN[SipW Signal Peptidase]\n    AN --> AO[TasA Cleavage and Maturation]\n    AO --> AP[TasA Polymerization]\n    AP --> AQ[Amyloid Fiber Formation]\n    AQ --> AR[Fibers Secreted to Matrix]\n    \n    %% AND Gate 2: Matrix Assembly\n    AK --> AS{AND: EPS Present<br/>AND TasA Present?}\n    AR --> AS\n    AS -->|No - One Component Only| AT[Weak Matrix]\n    AS -->|Yes - Both Present| AU[Strong Matrix Assembly]\n    \n    %% Motility Repression\n    U --> AV[/hag Flagellin Repression/]\n    AV --> AW[\\Flagella Synthesis Blocked/]\n    AW --> AX[Motility Lost]\n    \n    %% AND Gate 3: Biofilm Commitment\n    AU --> AY{AND: Matrix Present<br/>AND Motility Lost?}\n    AX --> AY\n    AY -->|No| AZ[\\Reversible State/]\n    AY -->|Yes| BA[Irreversible Biofilm Commitment]\n    \n    %% Biofilm Maturation\n    BA --> BB[Cell-Cell Adhesion]\n    BB --> BC[3D Architecture Development]\n    BC --> BD[Channels and Towers Formation]\n    BD --> BE[Nutrient Gradient Establishment]\n    \n    %% Heterogeneity and Division of Labor\n    BE --> BF{OR: Cell Fate<br/>Decision?}\n    BF -->|Matrix Producers| BG[High EPS/TasA Expression]\n    BF -->|Sporulation| BH[Spo0A Very High - Sporulation]\n    BF -->|Surfactin Producers| BI[Surfactin Synthesis]\n    \n    %% Final Outputs\n    BG --> BJ[Mature Biofilm Structure]\n    BH --> BJ\n    BI --> BJ\n    BJ --> BK([Biofilm Established])\n    M --> BL([Planktonic Growth])\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style A fill:#51cf66,color:#fff\n    style B fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill:#51cf66,color:#fff\n    style F fill:#51cf66,color:#fff\n    style G fill:#51cf66,color:#fff\n    style H fill:#51cf66,color:#fff\n    style I fill:#51cf66,color:#fff\n    style J fill:#51cf66,color:#fff\n    style K fill:#ffd600,color:#fff\n    style L fill:#42a5f5,color:#fff\n    style M fill:#b3e5fc,color:#000\n    style N fill:#42a5f5,color:#fff\n    style O fill:#b3e5fc,color:#000\n    style P fill:#b3e5fc,color:#000\n    style Q fill:#42a5f5,color:#fff\n    style R fill:#42a5f5,color:#fff\n    style S fill:#b3e5fc,color:#000\n    style T fill:#ffd600,color:#fff\n    style U fill:#42a5f5,color:#fff\n    style V fill:#42a5f5,color:#fff\n    style W fill:#000000,color:#fff\n    style X fill:#b3e5fc,color:#000\n    style Y fill:#e74c3c,color:#fff\n    style Z fill:#e74c3c,color:#fff\n    style AA fill:#e74c3c,color:#fff\n    style AB fill:#ffd600,color:#fff\n    style AC fill:#42a5f5,color:#fff\n    style AD fill:#42a5f5,color:#fff\n    style AE fill:#b3e5fc,color:#000\n    style AF fill:#ffa726,color:#fff\n    style AG fill:#42a5f5,color:#fff\n    style AH fill:#42a5f5,color:#fff\n    style AI fill:#42a5f5,color:#fff\n    style AJ fill:#42a5f5,color:#fff\n    style AK fill:#b3e5fc,color:#000\n    style AL fill:#ffa726,color:#fff\n    style AM fill:#ffa726,color:#fff\n    style AN fill:#51cf66,color:#fff\n    style AO fill:#42a5f5,color:#fff\n    style AP fill:#b3e5fc,color:#000\n    style AQ fill:#b3e5fc,color:#000\n    style AR fill:#b3e5fc,color:#000\n    style AS fill:#7950f2,color:#fff\n    style AT fill:#b3e5fc,color:#000\n    style AU fill:#42a5f5,color:#fff\n    style AV fill:#e74c3c,color:#fff\n    style AW fill:#e74c3c,color:#fff\n    style AX fill:#b3e5fc,color:#000\n    style AY fill:#7950f2,color:#fff\n    style AZ fill:#e74c3c,color:#fff\n    style BA fill:#b3e5fc,color:#000\n    style BB fill:#000000,color:#fff\n    style BC fill:#b3e5fc,color:#000\n    style BD fill:#b3e5fc,color:#000\n    style BE fill:#51cf66,color:#fff\n    style BF fill:#ffd600,color:#fff\n    style BG fill:#b3e5fc,color:#000\n    style BH fill:#b3e5fc,color:#000\n    style BI fill:#42a5f5,color:#fff\n    style BJ fill:#