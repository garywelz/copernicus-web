    "phosphate regulation",
    "Pho regulon",
    "PhoR",
    "PhoB",
    "PstSCAB",
    "alkaline phosphatase",
    "nutrient sensing",
    "two-component system",
    "phosphate scavenging",
    "Pho box"
  ],
  "lastUpdated": "2025-10-08",
