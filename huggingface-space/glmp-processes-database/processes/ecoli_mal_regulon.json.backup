    "maltose regulon",
    "MalT",
    "MalK",
    "multi-operon regulation",
    "maltose transport",
    "maltodextrin",
    "LamB",
    "coordinated expression",
    "CRP-cAMP",
    "ATP-dependent regulation"
  ],
