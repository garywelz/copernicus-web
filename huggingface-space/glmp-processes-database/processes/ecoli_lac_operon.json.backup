    "gene regulation",
    "transcriptional control",
    "catabolite repression",
    "lac repressor",
    "CAP-cAMP",
    "allolactose",
    "operon",
    "prokaryotic regulation",
    "beta-galactosidase",
    "lactose metabolism",
    "logic gates",
    "AND gates",
    "OR gates",
    "Boolean logic"
  ],
