  "mermaid": "graph TD\n    Start((\\1)) --> A1{Glucose entry route?}\n    \n    A1 -->|PTS system - most common| A2[Glucose + PEP \u2192 Glucose-6-P + Pyruvate]\n    A1 -->|Glucokinase pathway| A3[Glucose + ATP \u2192 Glucose-6-P + ADP]\n    \n    A2 --> A4[\"Step 1 complete: Glucose-6-phosphate G6P\"]\n    A3 --> A4\n    A4 --> A5[Committed to glycolysis - trapped in cell]\n    \n    A5 --> A6[\"Step 2: Phosphoglucose Isomerase Pgi\"]\n    A6 --> A7[Glucose-6-P \u21cc Fructose-6-P]\n    A7 --> A8[Aldose \u21cc Ketose isomerization]\n    \n    A8 --> A9[\"Step 3: Phosphofructokinase - RATE LIMITING\"]\n    A9 --> A10{Which PFK isoform?}\n    A10 -->|Pfk-1 major ATP-dependent| A11[Fructose-6-P + ATP \u2192 Fructose-1,6-bisP + ADP]\n    A10 -->|Pfk-2 minor PPi-dependent| A12[Fructose-6-P + PPi \u2192 Fructose-1,6-bisP + Pi]\n    \n    A11 --> A13[Fructose-1,6-bisphosphate F1,6BP]\n    A12 --> A13\n    \n    A13 --> A14{Allosteric regulation of Pfk?}\n    A14 -->|PEP high - inhibits| A15[/Feedback inhibition/]\n    A14 -->|AMP high - activates| A16[Energy deficit signal]\n    A14 -->|No regulation| A17[Basal activity]\n    \n    A15 --> A18[Glycolysis slowed]\n    A16 --> A19[Glycolysis accelerated]\n    A17 --> A20[Normal flux]\n    \n    A13 --> A21[\"Step 4: Fructose-bisphosphate Aldolase FbaAB\"]\n    A21 --> A22[Fructose-1,6-bisP \u21cc DHAP + G3P]\n    A22 --> A23[C6 \u2192 2 \u00d7 C3 split]\n    \n    A23 --> A24[Dihydroxyacetone phosphate DHAP]\n    A23 --> A25[Glyceraldehyde-3-phosphate G3P]\n    \n    A24 --> A26[\"Step 5: Triose Phosphate Isomerase TpiA\"]\n    A26 --> A27[DHAP \u21cc G3P]\n    A27 --> A28[Second G3P formed]\n    \n    A25 --> A29[Energy Payoff Phase begins]\n    A28 --> A29\n    A29 --> A30[Two G3P molecules proceed in parallel]\n    \n    A30 --> A31[\"Step 6: Glyceraldehyde-3-P Dehydrogenase GapA\"]\n    A31 --> A32{Substrates present?}\n    A32 -->|G3P + NAD+ + Pi| A33[Oxidation coupled to phosphorylation]\n    A32 -->|Missing cofactor| Wait1[Wait for NAD+]\n    Wait1 --> A32\n    \n    A33 --> A34[G3P + NAD+ + Pi \u2192 1,3-Bisphosphoglycerate + NADH]\n    A34 --> A35[First NADH produced - 2 total per glucose]\n    A35 --> A36[High-energy acyl phosphate formed]\n    \n    A36 --> A37[\"Step 7: Phosphoglycerate Kinase Pgk\"]\n    A37 --> A38[1,3-Bisphosphoglycerate + ADP \u2192 3-Phosphoglycerate + ATP]\n    A38 --> A39[Substrate-level phosphorylation]\n    A39 --> A40[First ATP produced - 2 total per glucose]\n    \n    A40 --> A41[\"Step 8: Phosphoglycerate Mutase GpmAB\"]\n    A41 --> A42[3-Phosphoglycerate \u21cc 2-Phosphoglycerate]\n    A42 --> A43[Phosphate group migration]\n    \n    A43 --> A44[\"Step 9: Enolase Eno\"]\n    A44 --> A45[2-Phosphoglycerate \u21cc Phosphoenolpyruvate PEP + H2O]\n    A45 --> A46[Dehydration creates high-energy phosphate]\n    \n    A46 --> A47[\"Step 10: Pyruvate Kinase PykAF\"]\n    A47 --> A48[PEP + ADP \u2192 Pyruvate + ATP]\n    A48 --> A49[Second substrate-level phosphorylation]\n    A49 --> A50[Second ATP produced - 2 total per glucose]\n    \n    A50 --> A51[Pyruvate formed - 2 per glucose]\n    \n    A51 --> A52[Energy Balance Sheet]\n    A52 --> A53[\"Investment: -2 ATP in steps 1 and 3\"]\n    A53 --> A54[\"Payoff: +4 ATP in steps 7 and 10\"]\n    A54 --> A55[\"Net: +2 ATP per glucose\"]\n    A55 --> A56[\"Plus: 2 NADH per glucose\"]\n    \n    A56 --> A57{Pyruvate fate?}\n    \n    A57 -->|Aerobic conditions| A58[Pyruvate \u2192 Acetyl-CoA via PDH]\n    A57 -->|Anaerobic - fermentation| A59[Pyruvate \u2192 Lactate or Ethanol]\n    A57 -->|Biosynthesis| A60[Pyruvate \u2192 Amino acids Ala, Val, Leu]\n    \n    A58 --> A61[Acetyl-CoA enters TCA cycle]\n    A61 --> A62[Complete oxidation to CO2]\n    A62 --> A63[\"Total yield: 30-32 ATP per glucose via OXPHOS\"]\n    \n    A59 --> A64[Mixed acid fermentation]\n    A64 --> A65[Lactate via LdhA regenerates NAD+]\n    A65 --> A66[Ethanol via AdhE regenerates NAD+]\n    A66 --> A67[Formate, Acetate also produced]\n    A67 --> A68[\"Net: 2 ATP per glucose only from glycolysis\"]\n    \n    A60 --> A69[Biosynthetic precursor]\n    \n    A4 --> A70{G6P branch point}\n    A70 -->|Glycolysis| A6\n    A70 -->|Pentose phosphate pathway| A71[G6P \u2192 Ribose-5-P + NADPH]\n    A70 -->|Gluconeogenesis reverse| A72[When glucose absent]\n    \n    A71 --> A73[NADPH for biosynthesis, ribose for nucleotides]\n    \n    A63 --> End1([Aerobic energy production])\n    A68 --> End2([Anaerobic fermentation])\n    A69 --> End3((\\1))\n    A73 --> End4([Alternative pathways])\n    A18 --> End5([Regulated flux])\n    A19 --> End5\n    A20 --> End5\n    \n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style A1 fill:#ffd600,color:#fff\n    style A2 fill:#b3e5fc,color:#000\n    style A3 fill:#b3e5fc,color:#000\n    style A4 fill:#000000,color:#fff\n    style A5 fill:#000000,color:#fff\n    style A6 fill:#42a5f5,color:#fff\n    style A7 fill:#b3e5fc,color:#000\n    style A8 fill:#b3e5fc,color:#000\n    style A9 fill:#42a5f5,color:#fff\n    style A10 fill:#ffd600,color:#fff\n    style A11 fill:#b3e5fc,color:#000\n    style A12 fill:#b3e5fc,color:#000\n    style A13 fill:#b3e5fc,color:#000\n    style A14 fill:#ffd600,color:#fff\n    style A15 fill:#e74c3c,color:#fff\n    style A16 fill:#51cf66,color:#fff\n    style A17 fill:#b3e5fc,color:#000\n    style A18 fill:#b3e5fc,color:#000\n    style A19 fill:#b3e5fc,color:#000\n    style A20 fill:#b3e5fc,color:#000\n    style A21 fill:#b3e5fc,color:#000\n    style A22 fill:#b3e5fc,color:#000\n    style A23 fill:#b3e5fc,color:#000\n    style A24 fill:#b3e5fc,color:#000\n    style A25 fill:#b3e5fc,color:#000\n    style A26 fill:#42a5f5,color:#fff\n    style A27 fill:#b3e5fc,color:#000\n    style A28 fill:#b3e5fc,color:#000\n    style A29 fill:#000000,color:#fff\n    style A30 fill:#b3e5fc,color:#000\n    style A31 fill:#b3e5fc,color:#000\n    style A32 fill:#ffd600