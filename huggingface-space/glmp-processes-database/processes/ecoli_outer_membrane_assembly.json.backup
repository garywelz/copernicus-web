    "and": 7,
    "not": 5,
    "or": 2
  },
  "mermaid": "graph TD\n    %% OMP Synthesis\n    A[OMP Gene Transcription] --> B[Ribosome Translation]\n    B --> C[N-terminal Signal Sequence]\n    C --> D[Unfolded OMP Polypeptide]\n    \n    %% Sec Translocation\n    D --> E[SecB Chaperone Binding]\n    E --> F[SecB-OMP Complex]\n    F --> G[Delivery to SecYEG]\n    G --> H{AND: SecA ATPase<br/>AND ATP?}\n    H -->|No| I[/Translocation Blocked/]\n    H -->|Yes| J[SecYEG Translocon]\n    \n    J --> K[Polypeptide Threading]\n    K --> L[Signal Peptidase Cleavage]\n    L --> M[OMP in Periplasm]\n    \n    %% Periplasmic Chaperone Handoff\n    M --> N{OR: Which<br/>Chaperone?}\n    N -->|Major - SurA| O[SurA Binding]\n    N -->|Alternative - Skp| P[Skp Binding]\n    N -->|Quality Control - DegP| Q[DegP Protease]\n    \n    %% SurA Pathway\n    O --> R[SurA PPIase Activity]\n    R --> S[Proline Isomerization]\n    S --> T[OMP Partially Folded]\n    T --> U[SurA-OMP Complex]\n    \n    %% Skp Pathway\n    P --> V[Skp Trimer]\n    V --> W[Hydrophobic Cavity]\n    W --> X[OMP Protected from Aggregation]\n    X --> Y[Skp-OMP Complex]\n    \n    %% DegP Quality Control\n    Q --> Z{AND: OMP Misfolded<br/>AND High Temp?}\n    Z -->|No| AA[Chaperone Activity]\n    Z -->|Yes| AB[Protease Activity]\n    AB --> AC[/Degradation/]\n    AC --> AD[/(Failed OMPs Removed)/]\n    \n    %% BAM Complex Recognition\n    U --> AE[Delivery to BAM]\n    Y --> AE\n    AA --> AE\n    AE --> AF[BAM Complex at OM]\n    \n    %% BAM Complex Assembly\n    AF --> AG{AND: BamA + BamB<br/>+ BamCDE?}\n    AG -->|No - Missing Subunits| AH[Assembly Fails]\n    AG -->|Yes - Complete| AI[/Functional BAM Complex/]\n    \n    AI --> AJ[BamA \u03b2-Barrel Core]\n    AJ --> AK[BamB Substrate Recognition]\n    AK --> AL[BamC/D/E Lipoproteins]\n    \n    %% \u03b2-Barrel Recognition\n    AL --> AM{AND: \u03b2-Barrel Signature<br/>Motif Present?}\n    AM -->|No - Not OMP| AN(\\1)\n    AM -->|Yes - OMP Motif| AO[Substrate Captured]\n    \n    AO --> AP[C-terminal \u03b2-Signal]\n    AP --> AQ[Aromatic Residues]\n    AQ --> AR[BamA Recognition]\n    \n    %% Insertion Mechanism\n    AR --> AS{AND: BamA Lateral<br/>Gate Open?}\n    AS -->|No| AT[Gate Closed]\n    AS -->|Yes| AU[Lateral Gate Opening]\n    \n    AU --> AV[OMP Enters BamA Barrel]\n    AV --> AW[\u03b2-Strand Insertion]\n    AW --> AX[Strand-by-Strand Threading]\n    AX --> AY[\u03b2-Barrel Nucleation]\n    \n    %% Lipid Interaction\n    AY --> AZ{AND: Lipid Bilayer<br/>Access?}\n    AZ -->|No| BA[Insertion Stalled]\n    AZ -->|Yes| BB[\u03b2-Barrel Interacts with Lipids]\n    \n    BB --> BC[Amphipathic \u03b2-Strands]\n    BC --> BD[Hydrophobic Face to Lipids]\n    BD --> BE[Hydrophilic Face to Interior]\n    \n    %% \u03b2-Barrel Closure\n    BE --> BF{AND: First + Last<br/>Strands Meet?}\n    BF -->|No| BG[Partial Barrel]\n    BF -->|Yes| BH[\u03b2-Barrel Closes]\n    \n    BH --> BI[Hydrogen Bonding]\n    BI --> BJ[Stable \u03b2-Barrel]\n    BJ --> BK[Release from BamA]\n    \n    %% Final OMP Structure\n    BK --> BL[OMP in Outer Membrane]\n    BL --> BM{OR: OMP<br/>Function?}\n    BM -->|Porin| BN[Small Molecule Transport]\n    BM -->|Adhesin| BO[Surface Attachment]\n    BM -->|Enzyme| BP[Catalytic Activity]\n    BM -->|Receptor| BQ[Signal Transduction]\n    \n    BN --> BR([Functional OMP])\n    BO --> BR\n    BP --> BR\n    BQ --> BR\n    \n    %% Failed Assembly\n    I --> BS[/(Cytoplasmic Degradation)/]\n    AH --> BS\n    AN --> BT[/Periplasmic Degradation/]\n    BA --> BT\n    BG --> BT\n    BT --> BU([Quality Control])\n    \n    %% Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n\n    %% Semantic Color Styling\n    style A fill:#51cf66,color:#fff\n    style B fill:#51cf66,color:#fff\n    style C fill:#51cf66,color:#fff\n    style D fill:#51cf66,color:#fff\n    style E fill:#51cf66,color:#fff\n    style F fill:#b3e5fc,color:#000\n    style G fill:#b3e5fc,color:#000\n    style H fill:#7950f2,color:#fff\n    style I fill:#e74c3c,color:#fff\n    style J fill:#b3e5fc,color:#000\n    style K fill:#b3e5fc,color:#000\n    style L fill:#51cf66,color:#fff\n    style M fill:#b3e5fc,color:#000\n    style N fill:#ffd600,color:#fff\n    style O fill:#42a5f5,color:#fff\n    style P fill:#42a5f5,color:#fff\n    style Q fill:#42a5f5,color:#fff\n    style R fill:#b3e5fc,color:#000\n    style S fill:#b3e5fc,color:#000\n    style T fill:#b3e5fc,color:#000\n    style U fill:#b3e5fc,color:#000\n    style V fill:#b3e5fc,color:#000\n    style W fill:#b3e5fc,color:#000\n    style X fill:#b3e5fc,color:#000\n    style Y fill:#b3e5fc,color:#000\n    style Z fill:#7950f2,color:#fff\n    style AA fill:#b3e5fc,color:#000\n    style AB fill:#42a5f5,color:#fff\n    style AC fill:#e74c3c,color:#fff\n    style AD fill:#e74c3c,color:#fff\n    style AE fill:#b3e5fc,color:#000\n    style AF fill:#b3e5fc,color:#000\n    style AG fill:#7950f2,color:#fff\n    style AH fill:#42a5f5,color:#fff\n    style AI fill:#b3e5fc,color:#000\n    style AJ fill:#b3e5fc,color:#000\n    style AK fill:#b3e5fc,color:#000\n    style AL fill:#ffa726,color:#fff\n    style AM fill:#7950f2,color:#fff\n    style AN fill:#b3e5fc,color:#000\n    style AO fill:#b3e5fc,color:#000\n    style AP fill:#51cf66,color:#fff\n    style AQ fill:#b3e5fc,color:#000\n    style AR fill:#b3e5fc,color:#000\n    style AS fill:#7950f2,color:#fff\n    style AT fill:#b3e5fc,color:#000\n    style AU fill:#b3e5fc,color:#000\n    style AV fill:#b3e5fc,color:#000\n    style AW fill:#b3e5fc,color:#000\n    style AX fill:#b3e5fc,color:#000\n    style AY fill:#b3e5fc,color:#000\n    style AZ fill:#7950f2,color:#fff\n    style BA fill:#b3e5fc,color:#000\n    style BB fill:#b3e5fc,color:#000\n    style BC fill:#b3e5fc,color:#000\n    style BD fill:#b3e5fc,color:#000\n    style BE fill:#b3e5fc,color:#000\n    style BF fill:#7950f2,color:#fff\n    style BG fill:#b3e5fc,color:#000\n    style BH fill:#b3e5fc,color:#000\n    style BI fill:#b3e5fc,color:#000\n    style BJ fill:#b3e5fc,color:#000\n    style BK fill:#b3e5fc,color:#000\n    style BL fill:#b3e5fc,color:#000\n    style BM fill:#ffd600,color:#fff\n    style BN fill:#42a5f5,color:#fff\n    style BO fill:#b3e5fc,color:#000\n    style BP fill:#b3e5fc,color:#000\n    style BQ fill:#51cf66,color:#fff\n    style BR fill:#b3e5fc,color:#000\n    style BS fill:#e74c3c,color:#fff\n    style BT fill:#e74c3c,color:#fff\n    style BU fill:#b3e5fc,color:#000",
